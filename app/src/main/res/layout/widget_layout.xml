<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0000000"
    android:padding="8dp">

    <!-- Single Book Layout (Height = 1) -->
    <LinearLayout
        android:id="@+id/widget_single_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="visible">

        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Cover"
            android:background="#333333"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="書籍タイトル"/>

            <TextView
                android:id="@+id/widget_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#BBBBBB"
                android:layout_marginTop="4dp"
                android:text="進捗: --%"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Multi-Book List Layout (Height >= 2) -->
    <LinearLayout
        android:id="@+id/widget_list_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/widget_row_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_row_1_cover"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#333333"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/widget_row_1_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/widget_row_1_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="#BBBBBB"/>
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/widget_divider_1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"/>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/widget_row_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_row_2_cover"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#333333"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/widget_row_2_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/widget_row_2_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="#BBBBBB"/>
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/widget_divider_2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"/>

        <!-- Row 3 -->
        <LinearLayout
            android:id="@+id/widget_row_3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_row_3_cover"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#333333"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/widget_row_3_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/widget_row_3_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="#BBBBBB"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
